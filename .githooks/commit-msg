#!/bin/bash

# ============================================================
# Git commit-msg hook — Commit message 格式校验
# 安装到 .git/hooks/commit-msg（需要 chmod +x）
# ============================================================

COMMIT_MSG_FILE="$1"

[ ! -f "$COMMIT_MSG_FILE" ] && exit 0

# 取第一行有效内容（跳过 git 注释行）
first_line=$(head -n 1 "$COMMIT_MSG_FILE" | sed 's/#.*//' | xargs)
[ -z "$first_line" ] && exit 0

pattern="^(feat|fix|docs|style|refactor|test|chore): .+"

if ! echo "$first_line" | grep -qE "$pattern"; then
  echo ""
  echo "[ERROR] Commit message 不符合规范"
  echo "  格式: 类型: 描述"
  echo "  类型: feat | fix | docs | style | refactor | test | chore"
  echo "  示例:"
  echo "    feat: 添加用户登录功能"
  echo "    fix: 修复登录页面崩溃"
  echo "    docs: 更新 API 文档"
  echo ""
  exit 1
fi

exit 0
