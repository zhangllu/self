#!/bin/bash

# ============================================================
# Git pre-commit hook — 文档规范 + 敏感文件检查
# 安装到 .git/hooks/pre-commit（需要 chmod +x）
# ============================================================

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

error() { echo -e "${RED}[ERROR]${NC} $1" >&2; HAD_ERRORS=1; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1" >&2; }

HAD_ERRORS=0

# === 1. 敏感文件检查 ===

while IFS= read -r file; do
  [ -z "$file" ] && continue
  fname=$(basename "$file")
  if [[ "$fname" == ".env" || "$fname" == .env.* || "$fname" == "credentials"* || "$fname" == *".key" || "$fname" == *".pem" ]]; then
    error "敏感文件被暂存: $file"
  fi
done < <(git diff --cached --name-only --diff-filter=ACMR)

# === 2. 文档规范：books/ 下 .md 文件 ===

while IFS= read -r file; do
  [ -z "$file" ] && continue

  content=$(git show :"$file" 2>/dev/null) || continue

  # 2a. Changelog 时间精确到分钟 (YYYY-MM-DD HH:MM，缺分钟则报错)
  while IFS= read -r line; do
    if [[ "$line" =~ ^###[[:space:]]+[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
      error "$file: Changelog 时间缺少分钟（需要 YYYY-MM-DD HH:MM）"
    fi
  done < <(echo "$content")

  # 2b. 禁止正文使用 --- 横线分隔符（排除 YAML frontmatter）
  has_fm=0
  echo "$content" | head -1 | grep -qE '^---[[:space:]]*$' && has_fm=1

  dash_count=0
  line_num=0
  while IFS= read -r line; do
    line_num=$((line_num + 1))
    if [[ "$line" =~ ^---[[:space:]]*$ ]]; then
      dash_count=$((dash_count + 1))
      # 跳过前 2 个 ---（YAML frontmatter 起始和结束）
      [ "$has_fm" -eq 1 ] && [ "$dash_count" -le 2 ] && continue
      error "$file: 第 ${line_num} 行: 使用了 --- 横线分隔符"
    fi
  done < <(echo "$content")
  # 2c. 禁止正文使用 > 块引用格式（灰色底纹）
  in_fm_block=0
  bl_line_num=0
  while IFS= read -r line; do
    bl_line_num=$((bl_line_num + 1))
    # 跳过 YAML frontmatter
    if [ "$bl_line_num" -eq 1 ] && [[ "$line" =~ ^---[[:space:]]*$ ]]; then
      in_fm_block=1
      continue
    fi
    if [ "$in_fm_block" -eq 1 ] && [[ "$line" =~ ^---[[:space:]]*$ ]]; then
      in_fm_block=0
      continue
    fi
    [ "$in_fm_block" -eq 1 ] && continue
    # 检测行首的 > 块引用
    if [[ "$line" =~ ^\>[[:space:]] ]]; then
      error "$file: 第 ${bl_line_num} 行: 使用了 > 块引用格式（灰色底纹）"
    fi
  done < <(echo "$content")

done < <(git diff --cached --name-only --diff-filter=ACMR -- 'books/*/chapters/*.md' 'books/*/drafts/*.md')

# === 3. Changelog 更新检查（仅修改的文件） ===

while IFS= read -r file; do
  [ -z "$file" ] && continue

  # 获取被暂存版本相对于 HEAD 的增量的行
  additions=$(git diff --cached "$file" 2>/dev/null | grep '^+' | grep -v '^+++')
  [ -z "$additions" ] && continue

  # 统计新增的 changelog 条目（形如 +### YYYY-MM-DD）
  has_changelog_entry=$(echo "$additions" | grep -cE '^\+### [0-9]{4}-[0-9]{2}-[0-9]{2}')
  # 统计非 changelog 条目的有内容新增
  has_content_change=$(echo "$additions" | grep -vE '^\+### [0-9]' | grep -cvE '^\+[[:space:]]*$')

  if [ "$has_content_change" -gt 0 ] && [ "$has_changelog_entry" -eq 0 ]; then
    warn "$file: 内容已修改但 Changelog 未更新"
  fi
done < <(git diff --cached --name-only --diff-filter=M -- 'books/*/chapters/*.md' 'books/*/drafts/*.md')

# === 4. README 同步检查 ===

docs_staged=$(git diff --cached --name-only --diff-filter=ACMR -- 'books/*/chapters/*.md' 'books/*/drafts/*.md' 2>/dev/null)
readme_staged=$(git diff --cached --name-only --diff-filter=ACMR -- 'README.md' 2>/dev/null)

if [ -n "$docs_staged" ] && [ -z "$readme_staged" ]; then
  warn "books/ 下有文件变更但 README.md 未同步更新（目录表/版本号）"
fi

exit $HAD_ERRORS
